/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model email_campaigns {
  id                 String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  name               String
  subject            String
  body_html          String
  body_text          String
  from_name          String        @default("DFW Daily")
  from_email         String        @default("hello@dfwdaily.com")
  filter_city        String?
  filter_category    String?
  filter_verified    Boolean?
  status             String        @default("draft")
  total_recipients   Int?          @default(0)
  sent_count         Int?          @default(0)
  failed_count       Int?          @default(0)
  opens_count        Int?          @default(0)
  clicks_count       Int?          @default(0)
  unsubscribes_count Int?          @default(0)
  created_at         DateTime?     @default(now()) @db.Timestamp(6)
  sent_at            DateTime?     @db.Timestamp(6)
  channel            String?       @default("email")
  body_sms           String?
  sms_sent_count     Int?          @default(0)
  sms_failed_count   Int?          @default(0)
  email_sends        email_sends[]
  sms_sends          sms_sends[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model email_sends {
  id              String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  campaign_id     String
  business_id     String
  email           String
  status          String          @default("pending")
  error_message   String?
  opened_at       DateTime?       @db.Timestamp(6)
  clicked_at      DateTime?       @db.Timestamp(6)
  unsubscribed_at DateTime?       @db.Timestamp(6)
  sent_at         DateTime?       @db.Timestamp(6)
  created_at      DateTime?       @default(now()) @db.Timestamp(6)
  email_campaigns email_campaigns @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([campaign_id], map: "idx_email_sends_campaign")
  @@index([status], map: "idx_email_sends_status")
}

model email_unsubscribes {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  email           String    @unique
  reason          String?
  unsubscribed_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([email], map: "idx_email_unsubscribes_email")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model sms_opt_outs {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  phone        String    @unique
  reason       String?
  opted_out_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([phone], map: "idx_sms_opt_outs_phone")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
