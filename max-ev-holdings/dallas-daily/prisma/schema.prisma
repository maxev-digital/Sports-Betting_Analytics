  campaign_id     String
  business_id     String
  phone           String
  status          String          @default("pending")
  error_message   String?
  twilio_sid      String?
  clicked_at      DateTime?       @db.Timestamp(6)
  opted_out_at    DateTime?       @db.Timestamp(6)
