generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model local_businesses {
  id                      String                    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                    String
  category                String?
  address                 String
  city                    String?
  state                   String?                   @default("TX")
  zip_code                String?
  latitude                Decimal?                  @db.Decimal
  longitude               Decimal?                  @db.Decimal
  phone                   String?
  website                 String?
  rating                  Decimal?                  @db.Decimal
  review_count            Int?
  price_level             Int?
  photo_url               String?
  google_place_id         String?                   @unique
  is_featured             Boolean                   @default(false)
  is_verified             Boolean                   @default(false)
  featured_tier           String?
  view_count              Int                       @default(0)
  click_count             Int                       @default(0)
  description             String?
  hours_of_operation      Json?
  google_maps_url         String?
  created_at              DateTime                  @default(now()) @db.Timestamp(6)
  updated_at              DateTime                  @default(now()) @db.Timestamp(6)
  photo_urls              String[]                  @default([])
  alcohol_sales_rank      Int?
  building_permit         String?
  business_status         String?
  construction_end        DateTime?                 @db.Timestamp(6)
  construction_start      DateTime?                 @db.Timestamp(6)
  has_liquor_license      Boolean                   @default(false)
  health_grade            String?
  health_score            Int?
  inspection_url          String?
  last_inspection         DateTime?                 @db.Timestamp(6)
  monthly_sales           Decimal?                  @db.Decimal
  permit_status           String?
  sales_tax_permit        String?
  tabc_permit             String?
  taxpayer_number         String?
  violations              Json?
  business_type           String?
  premium_tier            String?                   @default("free") @db.VarChar(20)
  premium_expires_at      DateTime?                 @db.Timestamp(6)
  premium_started_at      DateTime?                 @db.Timestamp(6)
  youtube_url             String?                   @db.VarChar(500)
  premium_bio             String?
  specialties             String[]
  owner_email             String?                   @db.VarChar(255)
  owner_name              String?                   @db.VarChar(255)
  owner_verified          Boolean?                  @default(false)
  claimed_at              DateTime?                 @db.Timestamp(6)
  dmag_url                String?                   @db.VarChar(500)
  dmag_awards             Json?
  featured_in_best_of     Boolean?                  @default(false)
  best_of_year            Int?
  best_of_category        String?                   @db.VarChar(100)
  years_in_business       Int?
  business_email          String?                   @db.VarChar(255)
  profile_views           Int?                      @default(0)
  quote_requests          Int?                      @default(0)
  phone_clicks            Int?                      @default(0)
  website_clicks          Int?                      @default(0)
  newsletter_features     Int?                      @default(0)
  last_newsletter_feature DateTime?                 @db.Timestamp(6)
  code_violations         Json?
  max_occupancy           Int?
  occupancy_permit        String?
  occupancy_status        String?
  occupancy_type          String?
  permit_issue_date       DateTime?                 @db.Timestamp(6)
  tabc_violations         Json?
  tier                    String?                   @default("free") @db.VarChar(20)
  user_id                 String?
  phone_verified          Boolean?                  @default(false)
  claim_token                  String?                   @unique @db.VarChar(255)
  claim_link_sent_at           DateTime?                 @db.Timestamp(6)
  claim_link_clicked_at        DateTime?                 @db.Timestamp(6)
  verification_code            String?                   @db.VarChar(10)
  verification_code_expires_at DateTime?                 @db.Timestamp(6)
  verification_attempts        Int?                      @default(0)
  code_verification_attempts   Int?                      @default(0)
  email_verified               Boolean?                  @default(false)
  email_verified_at            DateTime?                 @db.Timestamp(6)
  business_claim_requests      business_claim_requests[] @relation("business_claims")
  video_requests               video_requests[]           @relation("business_videos")
  deals                   deals[]
  partner_analytics       partner_analytics[]
  promo_codes             promo_codes[]

  @@index([latitude, longitude])
  @@index([category])
  @@index([is_featured, featured_tier])
  @@index([health_grade])
  @@index([alcohol_sales_rank])
  @@index([featured_in_best_of, best_of_year], map: "idx_best_of")
  @@index([owner_verified, claimed_at], map: "idx_claimed")
  @@index([premium_expires_at], map: "idx_premium_expires")
  @@index([premium_tier], map: "idx_premium_tier")
  @@index([tier], map: "idx_tier")
  @@index([user_id], map: "idx_user_id")
}

model articles {
  id           String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  studio_id    String              @default("dallas-daily")
  title        String
  description  String?
  content      String?
  image_url    String?
  source_name  String
  source_url   String              @unique
  category     String              @default("general")
  published_at DateTime            @db.Timestamp(6)
  is_featured  Boolean             @default(false)
  view_count   Int                 @default(0)
  created_at   DateTime            @default(now()) @db.Timestamp(6)
  updated_at   DateTime            @default(now()) @db.Timestamp(6)
  summaries    article_summaries[]

  @@index([category, published_at])
  @@index([is_featured, published_at])
}

model article_summaries {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  article_id   String
  persona_type String
  persona_name String
  summary_text String
  image_urls   String[]
  model        String?
  tokens_used  Int?
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @default(now()) @db.Timestamp(6)
  articles     articles @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@unique([article_id, persona_type])
  @@index([persona_type, created_at])
}

model deals {
  id               String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  business_id      String?
  business_name    String?
  title            String
  description      String?
  category         String?
  city             String?
  image_url        String?
  discount_amount  String?
  start_date       DateTime?         @db.Timestamp(6)
  end_date         DateTime?         @db.Timestamp(6)
  is_active        Boolean           @default(true)
  view_count       Int               @default(0)
  click_count      Int               @default(0)
  created_at       DateTime          @default(now()) @db.Timestamp(6)
  updated_at       DateTime          @default(now()) @db.Timestamp(6)
  dealType         String?           @default("manual")
  discount_percent Int?
  discount_price   Decimal?          @db.Decimal
  expires_at       DateTime?         @db.Timestamp(6)
  original_price   Decimal?          @db.Decimal
  source_name      String?
  source_url       String?
  local_businesses local_businesses? @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@index([is_active, end_date])
  @@index([dealType])
  @@index([city])
  @@index([category])
}

model users {
  id                     String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                  String    @unique
  name                   String?
  password_hash          String?
  role                   String    @default("user")
  subscription_tier      String    @default("free") @db.VarChar(20)
  subscription_status    String    @default("inactive") @db.VarChar(20)
  stripe_customer_id     String?   @db.VarChar(255)
  stripe_subscription_id String?   @db.VarChar(255)
  email_verified         Boolean   @default(false)
  created_at             DateTime  @default(now()) @db.Timestamp(6)
  updated_at             DateTime  @default(now()) @db.Timestamp(6)

  @@index([email])
  @@index([subscription_tier])
  @@index([stripe_customer_id])
}

model sessions {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  session_token String   @unique
  user_id       String
  expires       DateTime @db.Timestamp(6)
  created_at    DateTime @default(now()) @db.Timestamp(6)

  @@index([user_id])
}

model analytics_events {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  user_id    String?
  event_type String
  event_data Json?
  ip_address String?
  user_agent String?
  created_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([event_type, created_at])
}

model commercial_agents {
  id                   String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                 String
  title                String?
  company              String                  @default("Structure Commercial")
  email                String?
  phone                String?
  direct_line          String?
  bio                  String?
  credentials          String[]
  specializations      String[]
  photo_url            String?
  profile_url          String?
  external_profile_url String?
  linkedin_url         String?
  transaction_volume   BigInt?
  managed_sqft         Int?
  years_experience     Int?
  is_featured          Boolean                 @default(false)
  is_partner           Boolean                 @default(false)
  display_order        Int?
  created_at           DateTime                @default(now()) @db.Timestamp(6)
  updated_at           DateTime                @default(now()) @db.Timestamp(6)
  office_address       String?
  screenshot_url       String?
  slug                 String?                 @unique
  properties           commercial_properties[]

  @@index([is_featured])
  @@index([is_partner])
  @@index([slug])
}

model commercial_properties {
  id             String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  name           String
  address        String
  city           String?
  state          String?            @default("TX")
  zip_code       String?
  property_type  String?
  total_sqft     Int?
  available_sqft Int?
  price_per_sqft Decimal?           @db.Decimal
  lease_type     String?
  building_class String?
  features       Json?
  images         String[]
  description    String?
  external_url   String?
  agent_id       String?
  company        String             @default("Structure Commercial")
  is_featured    Boolean            @default(false)
  status         String             @default("available")
  created_at     DateTime           @default(now()) @db.Timestamp(6)
  updated_at     DateTime           @default(now()) @db.Timestamp(6)
  agent          commercial_agents? @relation(fields: [agent_id], references: [id])

  @@index([agent_id])
  @@index([is_featured])
  @@index([property_type])
  @@index([status])
}

model residential_properties {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  listing_id     String?  @unique
  address        String
  city           String?
  state          String?  @default("TX")
  zip_code       String?
  price          Int?
  bedrooms       Int?
  bathrooms      Decimal? @db.Decimal
  sqft           Int?
  lot_sqft       Int?
  property_type  String?
  year_built     Int?
  images         String[]
  description    String?
  features       Json?
  listing_url    String?
  status         String   @default("for_sale")
  days_on_market Int?
  is_featured    Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamp(6)
  updated_at     DateTime @default(now()) @db.Timestamp(6)

  @@index([city])
  @@index([price])
  @@index([bedrooms])
  @@index([status])
  @@index([is_featured])
}

model promo_codes {
  id             String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  business_id    String
  code           String              @unique @db.VarChar(50)
  discount_type  String              @db.VarChar(20)
  discount_value Decimal?            @db.Decimal(10, 2)
  description    String
  valid_from     DateTime            @db.Timestamp(6)
  valid_until    DateTime            @db.Timestamp(6)
  is_active      Boolean             @default(true)
  views          Int                 @default(0)
  clicks         Int                 @default(0)
  redemptions    Int                 @default(0)
  total_revenue  Decimal             @default(0) @db.Decimal(10, 2)
  created_at     DateTime            @default(now()) @db.Timestamp(6)
  updated_at     DateTime            @default(now()) @db.Timestamp(6)
  events         promo_code_events[]
  business       local_businesses    @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@index([code])
  @@index([is_active, valid_until])
}

model promo_code_events {
  id              String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  promo_code_id   String
  event_type      String      @db.VarChar(20)
  sale_amount     Decimal?    @db.Decimal(10, 2)
  customer_name   String?     @db.VarChar(255)
  event_timestamp DateTime    @default(now()) @db.Timestamp(6)
  ip_address      String?     @db.VarChar(50)
  user_agent      String?
  promo_code      promo_codes @relation(fields: [promo_code_id], references: [id], onDelete: Cascade)

  @@index([promo_code_id, event_type])
  @@index([event_timestamp])
}

model partner_analytics {
  id                String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  business_id       String
  period_type       String           @db.VarChar(20)
  period_start      DateTime         @db.Timestamp(6)
  period_end        DateTime         @db.Timestamp(6)
  promo_redemptions Int              @default(0)
  promo_revenue     Decimal          @default(0) @db.Decimal(10, 2)
  calculated_roi    Decimal          @default(0) @db.Decimal(10, 2)
  profile_views     Int?             @default(0)
  phone_clicks      Int?             @default(0)
  website_clicks    Int?             @default(0)
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @default(now()) @db.Timestamp(6)
  business          local_businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id, period_type, period_start])
  @@index([period_start, period_end])
}

model business_claim_requests {
  id                 String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  business_id        String
  email              String           @db.VarChar(255)
  verification_token String           @unique @db.VarChar(255)
  status             String           @default("pending") @db.VarChar(50)
  expires_at         DateTime         @db.Timestamp(6)
  verified_at        DateTime?        @db.Timestamp(6)
  created_at         DateTime         @default(now()) @db.Timestamp(6)
  updated_at         DateTime         @default(now()) @db.Timestamp(6)
  local_businesses   local_businesses @relation("business_claims", fields: [business_id], references: [id], onDelete: Cascade)

  @@index([verification_token], map: "idx_business_claim_token")
  @@index([status], map: "idx_business_claim_status")
  @@index([business_id], map: "idx_business_claim_business_id")
}

model newsletter_issues {
  id                 String             @id
  issue_number       Int?
  issue_date         DateTime           @db.Date
  frequency          String
  content            Json
  subject_line       String
  preview_text       String?
  status             String?            @default("draft")
  generated_at       DateTime?          @default(now()) @db.Timestamp(6)
  approved_at        DateTime?          @db.Timestamp(6)
  approved_by        String?
  sent_at            DateTime?          @db.Timestamp(6)
  total_recipients   Int?               @default(0)
  delivered_count    Int?               @default(0)
  opened_count       Int?               @default(0)
  clicked_count      Int?               @default(0)
  unsubscribed_count Int?               @default(0)
  created_at         DateTime?          @default(now()) @db.Timestamp(6)
  updated_at         DateTime?          @default(now()) @db.Timestamp(6)
  newsletter_sends   newsletter_sends[]

  @@index([issue_date], map: "idx_newsletter_issues_date")
  @@index([status], map: "idx_newsletter_issues_status")
}

model newsletter_sends {
  id                   String            @id
  issue_id             String
  subscriber_id        String
  personalized_content Json?
  sent_at              DateTime?         @db.Timestamp(6)
  delivered_at         DateTime?         @db.Timestamp(6)
  opened_at            DateTime?         @db.Timestamp(6)
  clicked_at           DateTime?         @db.Timestamp(6)
  unsubscribed_at      DateTime?         @db.Timestamp(6)
  bounced_at           DateTime?         @db.Timestamp(6)
  status               String?           @default("pending")
  email_id             String?
  error_message        String?
  created_at           DateTime?         @default(now()) @db.Timestamp(6)
  newsletter_issues    newsletter_issues @relation(fields: [issue_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscribers          subscribers       @relation(fields: [subscriber_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([issue_id], map: "idx_newsletter_sends_issue")
  @@index([status], map: "idx_newsletter_sends_status")
  @@index([subscriber_id], map: "idx_newsletter_sends_subscriber")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model automation_workflows {
  id                   String                 @id
  name                 String
  workflow_type        String
  trigger_event        String
  trigger_conditions   Json?
  emails               Json
  active               Boolean?               @default(true)
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  workflow_enrollments workflow_enrollments[]

  @@index([active], map: "idx_automation_workflows_active")
  @@index([workflow_type], map: "idx_automation_workflows_type")
}

