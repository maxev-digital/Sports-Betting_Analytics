model subscriber_preference_changes {
  id            String      @id
  subscriber_id String
  changed_field String
  old_value     Json?
  new_value     Json?
  changed_at    DateTime?   @default(now()) @db.Timestamp(6)
  subscribers   subscribers @relation(fields: [subscriber_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([subscriber_id], map: "idx_subscriber_preference_changes_subscriber")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model subscribers {
  id                            String                          @id
  email                         String                          @unique
  phone                         String?
  name                          String?
  city                          String?
  zip_code                      String?
  interests                     Json?                           @default("[]")
  locations                     Json?                           @default("[]")
  frequency                     String?                         @default("daily")
  timezone                      String?                         @default("America/Chicago")
  status                        String?                         @default("pending")
  confirmed_at                  DateTime?                       @db.Timestamp(6)
  unsubscribed_at               DateTime?                       @db.Timestamp(6)
  last_opened_at                DateTime?                       @db.Timestamp(6)
  last_clicked_at               DateTime?                       @db.Timestamp(6)
  total_opens                   Int?                            @default(0)
  total_clicks                  Int?                            @default(0)
  signup_source                 String?
  referral_code                 String?
  created_at                    DateTime?                       @default(now()) @db.Timestamp(6)
  updated_at                    DateTime?                       @default(now()) @db.Timestamp(6)
  newsletter_sends              newsletter_sends[]
  subscriber_preference_changes subscriber_preference_changes[]
  workflow_enrollments          workflow_enrollments[]

  @@index([email], map: "idx_subscribers_email")
  @@index([interests], map: "idx_subscribers_interests", type: Gin)
  @@index([locations], map: "idx_subscribers_locations", type: Gin)
  @@index([status], map: "idx_subscribers_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model workflow_enrollments {
  id                   String               @id
  workflow_id          String
  subscriber_id        String
  current_step         Int?                 @default(0)
  completed_steps      Json?                @default("[]")
  status               String?              @default("active")
  enrolled_at          DateTime?            @default(now()) @db.Timestamp(6)
  completed_at         DateTime?            @db.Timestamp(6)
  next_send_at         DateTime?            @db.Timestamp(6)
  created_at           DateTime?            @default(now()) @db.Timestamp(6)
  updated_at           DateTime?            @default(now()) @db.Timestamp(6)
  subscribers          subscribers          @relation(fields: [subscriber_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  automation_workflows automation_workflows @relation(fields: [workflow_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([next_send_at], map: "idx_workflow_enrollments_next_send")
  @@index([status], map: "idx_workflow_enrollments_status")
  @@index([subscriber_id], map: "idx_workflow_enrollments_subscriber")
  @@index([workflow_id], map: "idx_workflow_enrollments_workflow")
}

model newsletter_templates {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name            String
  description     String?
  html_content    String
  placeholders    String[]
  thumbnail_url   String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @default(now()) @db.Timestamp(6)

  @@index([is_active])
}

model video_requests {
  id               String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  business_id      String
  business_name    String            @db.VarChar(255)
  contact_name     String            @db.VarChar(255)
  contact_email    String            @db.VarChar(255)
  contact_phone    String?           @db.VarChar(50)
  services         String
  tagline          String?           @db.VarChar(500)
  tone             String            @default("professional") @db.VarChar(50)
  assets_notes     String?
  additional_notes String?
  status           String            @default("requested") @db.VarChar(50)
  youtube_url      String?           @db.VarChar(500)
  youtube_title    String?           @db.VarChar(255)
  admin_notes      String?
  requested_at     DateTime          @default(now()) @db.Timestamp(6)
  in_production_at DateTime?         @db.Timestamp(6)
  published_at     DateTime?         @db.Timestamp(6)
  updated_at       DateTime          @default(now()) @db.Timestamp(6)
  local_businesses local_businesses  @relation("business_videos", fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id], map: "idx_video_requests_business")
  @@index([status], map: "idx_video_requests_status")
}

model outreach_config {
  id                    Int       @id @default(1)
  is_paused             Boolean   @default(false)
  daily_cap             Int       @default(300)
  contact_cooldown_days Int       @default(30)
  template_type         String    @default("auto") @db.VarChar(20)
  last_run_at           DateTime?
  last_run_sent         Int       @default(0)
  last_run_failed       Int       @default(0)
  last_run_skipped      Int       @default(0)
  total_sent_alltime    Int       @default(0)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
}

model business_discovery_log {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  source      String   @db.VarChar(50)
  city        String   @db.VarChar(100)
  category    String   @db.VarChar(100)
  discovered  Int      @default(0)
  inserted    Int      @default(0)
  duplicates  Int      @default(0)
  errors      Int      @default(0)
  ran_at      DateTime @default(now())

  @@index([ran_at])
  @@index([source])
}

model business_enrichment_log {
  id               String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  business_id      String
  enrichment_type  String   @db.VarChar(50)
  status           String   @db.VarChar(20)
  result           String?  @db.VarChar(255)
  ran_at           DateTime @default(now())

  @@index([business_id])
  @@index([ran_at])
}

// ============================================================
// HIGH SCHOOL SPORTS - DFW Metroplex
// ============================================================

model hs_schools {
  id                  String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                String   // "Allen High School"
  short_name          String   // "Allen"
  mascot              String?  // "Eagles"
  isd                 String   // "Allen ISD"
  city                String
  county              String   // "Collin", "Dallas", "Tarrant", "Denton", "Rockwall", etc.
  state               String   @default("TX")
  address             String?
  zip_code            String?
  uil_classification  String   // "6A", "5A", "4A", "3A", "2A", "1A"
  enrollment          Int?
  colors_primary      String?  // e.g. "#1A237E"
  colors_secondary    String?
  mascot_image_url    String?
  athletic_website    String?
  athletic_net_id     String?  @unique // AthleticNet school ID for API sync
  maxpreps_slug       String?  // maxpreps.com URL slug
  uil_school_id       String?  // UIL internal ID
  latitude            Decimal? @db.Decimal
  longitude           Decimal? @db.Decimal
  created_at          DateTime @default(now()) @db.Timestamp(6)
  updated_at          DateTime @default(now()) @db.Timestamp(6)

  home_games           hs_games[]           @relation("HomeSchool")
  away_games           hs_games[]           @relation("AwaySchool")
  track_results        hs_track_results[]
  athletes             hs_athletes[]
  standings            hs_standings[]
  district_memberships hs_school_districts[]

  @@index([isd])
  @@index([county])
  @@index([uil_classification])
  @@index([city])
}

model hs_districts {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name           String   // "District 5-6A"
  number         String   // "5"
  classification String   // "6A"
  region         String?  // "Region 2"
  sport          String   // "Football", "Basketball", "Track & Field", "All"
  season_year    Int
  created_at     DateTime @default(now()) @db.Timestamp(6)

  schools   hs_school_districts[]
  standings hs_standings[]

  @@unique([number, classification, sport, season_year])
  @@index([classification, sport, season_year])
}

model hs_school_districts {
  id          String @id @default(dbgenerated("(gen_random_uuid())::text"))
  school_id   String
  district_id String
  sport       String
  season_year Int

  school   hs_schools   @relation(fields: [school_id], references: [id])
  district hs_districts @relation(fields: [district_id], references: [id])

  @@unique([school_id, district_id, sport, season_year])
  @@index([school_id, sport])
  @@index([district_id])
}

model hs_standings {
  id                    String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  school_id             String
  district_id           String
  sport                 String
  season_year           Int
  overall_wins          Int      @default(0)
  overall_losses        Int      @default(0)
  overall_ties          Int      @default(0)
  district_wins         Int      @default(0)
  district_losses       Int      @default(0)
  district_ties         Int      @default(0)
  points_for            Int?
  points_against        Int?
  district_rank         Int?
  playoff_seed          Int?
  made_playoffs         Boolean  @default(false)
  playoff_round_reached String?  // "Bi-District", "Area", "Regional QF", "Regional Final", "State SF", "State Final", "State Champion"
  updated_at            DateTime @default(now()) @db.Timestamp(6)

  school   hs_schools   @relation(fields: [school_id], references: [id])
  district hs_districts @relation(fields: [district_id], references: [id])

  @@unique([school_id, sport, season_year])
  @@index([sport, season_year])
  @@index([district_id, sport, season_year])
}

model hs_games {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  home_school_id String?
  away_school_id String?
  sport          String
  game_date      DateTime  @db.Timestamp(6)
  home_score     Int?
  away_score     Int?
  is_district    Boolean   @default(false)
  is_playoff     Boolean   @default(false)
  playoff_round  String?
  season_year    Int
  location       String?
  venue          String?
  notes          String?
  source         String?   // "UIL", "MaxPreps", "Manual", "ScoreStream"
  created_at     DateTime  @default(now()) @db.Timestamp(6)

  home_school hs_schools? @relation("HomeSchool", fields: [home_school_id], references: [id])
  away_school hs_schools? @relation("AwaySchool", fields: [away_school_id], references: [id])

  @@index([sport, season_year])
  @@index([game_date])
  @@index([home_school_id, sport])
}

model hs_track_meets {
  id                   String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                 String
  meet_date            DateTime @db.Timestamp(6)
  location             String?
  city                 String?
  athletic_net_meet_id String?  @unique
  season_year          Int
  meet_type            String   // "Invitational", "District", "Area", "Regional", "State"
  gender               String?  // "M", "F", "Mixed"
  created_at           DateTime @default(now()) @db.Timestamp(6)

  results hs_track_results[]

  @@index([season_year, meet_type])
  @@index([meet_date])
}

model hs_track_results {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  meet_id        String
  school_id      String
  athlete_name   String
  athlete_grade  Int?     // 9, 10, 11, 12
  gender         String   // "M", "F"
  event          String   // "100m", "200m", "400m", "800m", "1600m", "3200m", "110mH", "300mH", "4x100", "4x200", "4x400", "4x800", "High Jump", "Long Jump", "Triple Jump", "Pole Vault", "Shot Put", "Discus", "Javelin"
  result         String   // "10.45" or "58-03.00"
  result_seconds Decimal? @db.Decimal // for time events converted to seconds for sorting
  result_meters  Decimal? @db.Decimal // for field events in meters for sorting
  place          Int?
  wind           String?  // wind reading for sprints (e.g. "+1.2")
  is_pr          Boolean  @default(false)
  is_season_best Boolean  @default(false)
  relay_legs     String?  // for relays: comma-separated leg runner names
  created_at     DateTime @default(now()) @db.Timestamp(6)

  meet   hs_track_meets @relation(fields: [meet_id], references: [id])
  school hs_schools     @relation(fields: [school_id], references: [id])

  @@index([school_id, event])
  @@index([gender, event, result_seconds])
  @@index([meet_id])
}

model hs_athletes {
  id                      String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                    String
  school_id               String
  grad_year               Int?
  gender                  String   // "M", "F"
  athletic_net_athlete_id String?  @unique
  events                  String[] @default([])
  created_at              DateTime @default(now()) @db.Timestamp(6)
  updated_at              DateTime @default(now()) @db.Timestamp(6)

  school hs_schools      @relation(fields: [school_id], references: [id])
  prs    hs_athlete_prs[]

  @@index([school_id])
  @@index([name])
}

model hs_athlete_prs {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  athlete_id     String
  event          String
  pr_result      String    // human readable: "4:12.45" or "52-06.00"
  pr_seconds     Decimal?  @db.Decimal // for sorting time events
  pr_meters      Decimal?  @db.Decimal // for sorting field events
  pr_date        DateTime? @db.Timestamp(6)
  season_year    Int?
  is_lifetime_pr Boolean   @default(true)
  updated_at     DateTime  @default(now()) @db.Timestamp(6)

  athlete hs_athletes @relation(fields: [athlete_id], references: [id])

  @@unique([athlete_id, event])
  @@index([event, pr_seconds])
}

model scheduled_content {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  content_type   String    @db.VarChar(50)
  title          String    @db.VarChar(500)
  content        Json
  scheduled_for  DateTime  @db.Timestamp(6)
  publish_status String    @default("scheduled") @db.VarChar(50)
  published_at   DateTime? @db.Timestamp(6)
  platforms      String[]
  metadata       Json?
  error_message  String?
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  updated_at     DateTime  @default(now()) @db.Timestamp(6)

  @@index([publish_status])
  @@index([scheduled_for])
}
