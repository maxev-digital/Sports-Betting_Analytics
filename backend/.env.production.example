# MaxEV Sports - Production Environment Variables
# Copy this file to .env.production and fill in your actual values

# Environment
ENVIRONMENT=production
DEBUG=False

# Server Configuration
HOST=0.0.0.0
PORT=8000

# API Keys
ODDS_API_KEY=your_odds_api_key_here

# Google Sheets Integration
GOOGLE_SHEETS_CREDENTIALS=/home/username/maxevsports-backend/credentials.json
GOOGLE_SHEETS_SHEET_ID=1bFNPXj2wOOBid8d-dnHbKmSs5U90a66X29-PFRmkgvo

# Security
SECRET_KEY=generate_with_openssl_rand_base64_32
ALLOWED_HOSTS=max-ev-sports.com,www.max-ev-sports.com,api.max-ev-sports.com

# Database (if applicable)
DATABASE_URL=postgresql://user:password@localhost/maxevsports

# CORS Origins (comma-separated)
CORS_ORIGINS=https://max-ev-sports.com,https://www.max-ev-sports.com,https://api.max-ev-sports.com,chrome-extension://*

# WebSocket Configuration
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
WS_MAX_CONNECTIONS=1000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/maxevsports/backend.log

# Performance
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
