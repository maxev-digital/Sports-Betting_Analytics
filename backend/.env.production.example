# ARB Auto Bettor - Production Environment Variables
# Copy this file to .env.production and fill in your actual values

# Environment
ENVIRONMENT=production
DEBUG=False

# Server Configuration
HOST=0.0.0.0
PORT=8000

# API Keys
ODDS_API_KEY=your_odds_api_key_here

# Google Sheets Integration
GOOGLE_SHEETS_CREDENTIALS=/home/username/sporttrader-backend/credentials.json
GOOGLE_SHEETS_SHEET_ID=1bFNPXj2wOOBid8d-dnHbKmSs5U90a66X29-PFRmkgvo

# Security
SECRET_KEY=generate_with_openssl_rand_base64_32
ALLOWED_HOSTS=sporttrader.io,www.sporttrader.io,api.sporttrader.io

# Database (if applicable)
DATABASE_URL=postgresql://user:password@localhost/arbdb

# CORS Origins (comma-separated)
CORS_ORIGINS=https://sporttrader.io,https://www.sporttrader.io,https://api.sporttrader.io,chrome-extension://*

# WebSocket Configuration
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
WS_MAX_CONNECTIONS=1000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/sporttrader/backend.log

# Performance
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
