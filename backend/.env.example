# The Odds API - Get your free API key at https://the-odds-api.com/
# Sign up for free tier (500 requests/month) or paid plans for higher limits
ODDS_API_KEY=your_odds_api_key_here

# Google Sheets Integration (Optional - for exporting predictions and tracking)
# Path to your Google Cloud service account credentials JSON file
GOOGLE_SHEETS_CREDENTIALS=google_sheets/credentials/service-account-key.json

# Google Sheet IDs (found in the sheet URL: docs.google.com/spreadsheets/d/{SHEET_ID}/edit)
GOOGLE_SHEETS_SHEET_ID=your_nba_sheet_id_here
GOOGLE_SHEETS_SHEET_ID_NCAAB=your_ncaab_sheet_id_here

# Instructions:
# 1. Copy this file to .env in the same directory
# 2. Replace the placeholder values with your actual credentials
# 3. NEVER commit the .env file to git (it's already in .gitignore)

# Eleven Labs API - For generating sound effects (Optional)
# Get your API key at https://elevenlabs.io/
ELEVEN_LABS_API_KEY=your_eleven_labs_api_key_here
